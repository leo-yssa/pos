# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Allow vendored jars for Swing frontend
!frontend/lib/*.jar

# Build outputs
build/
.tmp_build/

# Maven outputs
**/target/

# Eclipse outputs
frontend/bin/

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*
